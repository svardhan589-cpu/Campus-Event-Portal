<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Campus Event Portal</title>
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" integrity="sha384-JcKb8q3iqJ61gNV9KGb8thSsNjpSL0n8PARn9HuZOnIxN0hoP+VmmDGMN5t9UJ0Z" crossorigin="anonymous" />
    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js" integrity="sha384-DfXdz2htPH0lsSSs5nCTpuj/zy4C+OGpamoFVy38MVBnE+IbbVYUew+OrCXaRkfj" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js" integrity="sha384-9/reFTGAW83EW2RDu2S0VKaIzap3H66lZH81PoYlFhbGU+6BZp6G7niu735Sk7lN" crossorigin="anonymous"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js" integrity="sha384-B4gt1jrGC7Jh4AgTPSdUtOBvfO8shuf57BaghqFfPlYxofvL8/KUEfYiJOMMV+rV" crossorigin="anonymous"></script>
</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar">
        <div class="container">
            <h2 class="logo"> <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQTUbl4uFu8aYxKa7-6nqUj9dcv8YF_cNIQZA&s  " class="logo1">Campus Event Portal</h2>

            <input type="checkbox" id="menu-toggle">
            <label for="menu-toggle" class="menu-icon">&#9776;</label>

            <ul class="nav-links">
                <li><a href="#home">Home</a></li>
                <li><a href="#about">About</a></li>
                <li><a href="#events">Events</a></li>
                <li><a href="#gallery">Gallery</a></li>
                <li><a href="#register">Register</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
        </div>
    </nav>

    <!-- HERO -->
    <header id="home" class="hero">
        <div class="hero-content">
            <h1 class="head-color">Welcome to Campus Event Portal</h1>
            <a href="#events" class="btn">Explore Events</a>
            <p class="pera">Explore all campus fests, sports, cultural and technical events.</p>
        </div>
    </header>

    <!-- ABOUT -->
    <section id="about" class="section">
        <h2 class="title">About</h2>
        <p class="text">
            This portal provides complete details on all major college activities including Hackathons,
            Sports Meets, Cultural Fest, and Technical Expos. Stay updated & participate easily.
        </p>
    </section>

    <!-- EVENTS -->
    <section id="events" class="section bg-light">
        <h2 class="title">Events</h2>

        <div class="event-grid">

            <div class="event-card" onclick="openSection('hackathon')">
                <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRSda1CXJA1BHEcx8iXUnEkO5fxgC7Nt7Aa6Q&s">
                <h3>Hackathon</h3>
                <p>24-hour coding challenge for problem solvers.</p>
            </div>

            <div class="event-card" onclick="openSection('sports')">
                <img src="https://satg.telangana.gov.in/public/frontendpages/images/banner.png">
                <h3>Sports Meet</h3>
                <p>Multiple inter-college sports competitions.</p>
            </div>

            <div class="event-card" onclick="openSection('cultural')">
                <img src="https://img1.wsimg.com/isteam/stock/ub69pPpJ27t6nR13E/:/cr=t:0%25,l:0%25,w:100%25,h:100%25/rs=w:400,cg:true">
                <h3>Cultural Fest</h3>
                <p>Dance, music, drama & cultural activities.</p>
            </div>

            <div class="event-card" onclick="openSection('technical')">
                <img src="https://www.grantthornton.in/globalassets/1.-member-firms/india/new-homepage/media/1440x408px/1440x408px_hero_banner_shutterstock_1633125442.jpg">
                <h3>Technical Expo</h3>
                <p>Project exhibitions and innovative demos.</p>
            </div>

        </div>
    </section>

    <!-- EVENT DETAILS -->
    <section id="hackathon" class="event-details">
        <h2>Hackathon - Event Details</h2>
        <p>✓ 24-hour nonstop coding competition</p>
        <p>✓ Team size: 2–4 members</p>
        <p>✓ Problem statements from real companies</p>
        <p>✓ Prizes worth ₹50,000</p>
    </section>

    <section id="sports" class="event-details">
        <h2>Sports Meet - Event Details</h2>
        <p>Cricket, Volleyball, Kabaddi, Football — Inter-college championships.</p>
        <p>Opening ceremony includes torch run and march past.</p>
    </section>

    <section id="cultural" class="event-details">
        <h2>Cultural Fest - Event Details</h2>
        <p>Dance, singing, drama, mimicry, fashion show, DJ night.</p>
        <p>Special guest performances included.</p>
    </section>

    <section id="technical" class="event-details">
        <h2>Technical Expo - Event Details</h2>
        <p>Project expo for all engineering departments.</p>
        <p>Robotics, IoT, AI, ML, AR/VR demos.</p>
    </section>

    <!-- GALLERY -->
    <section id="gallery" class="section">
        <h2 class="title">Gallery</h2>

        <div class="gallery-grid">
            <img src="https://franchiseindia.s3.ap-south-1.amazonaws.com/uploads/content/edu/art/5b223d94ba43e.jpg">
            <img src="https://mitbishnupur.ac.in/assets/upload/609793_WhatsApp_Image_2025-05-31_at_10_53_02_AM.jpeg">
            <img src="https://www.brightidea.com/wp-content/uploads/Who_Participates_in_a_Hackathon.png">
            <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRyLADS2jz1iEEhNSYgXqP1SCq9SYdFTCmBrA&s">
            <img src="https://www.eventbrite.com/blog/wp-content/uploads/2023/02/image5-min-1.png">

        </div>
    </section>

    <!-- REGISTRATION -->
    <section id="register" class="section bg-light">
        <h2 class="title">Event Registration</h2>

        <form class="form">
            <input type="text" placeholder="Full Name" required>
            <input type="email" placeholder="College Email" required>
            <input type="number" placeholder="Phone Number" required>

            <select required>
                <option value="">Select Event</option>
                <option>Hackathon</option>
                <option>Sports Meet</option>
                <option>Cultural Fest</option>
                <option>Technical Expo</option>
            </select>

            <button type="submit" class="btn">Submit</button>
        </form>
    </section>

    <!-- CONTACT -->
    <section id="contact" class="section">
        <h2 class="title">Contact</h2>
        <p class="text">For queries, contact:</p>
        <p><b>Email:</b> eventsupport@college.com</p>
        <p><b>Phone:</b> +91 98765 43210</p>
    </section>

    <!-- FOOTER -->
    <footer class="footer">
        © 2025 Campus Event Portal — All Rights Reserved
    </footer>
    <script>
        function openSection(id) {
            document.querySelectorAll('.event-details').forEach(sec => {
                sec.style.display = 'none';
            });

            document.getElementById(id).style.display = 'block';
            document.getElementById(id).scrollIntoView({
                behavior: "smooth"
            });
        }
    </script>

</body>

</html>
